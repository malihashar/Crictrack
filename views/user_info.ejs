
    
<html>
<head>
    <title>Cric Track - Profile</title>
    <link rel="stylesheet" href="/stylesheets/input.css">
</head>

<header>
    <div class="logo">
        
    </div>
  
</header>

<body>
<div class="sidebar">
  <h3>Cric Track</h3>

  <a href="/c">Home</a>
  <a href="/b">New Player</a>

  <% if (typeof user !== "undefined") { %>
    <a href="/d/<%= user._id %>">Profile</a>
    <a href="/stats/<%= user._id %>">Stats</a>
  <% } %>

</div>
<div class="profile-container">
    <div class="profile-card">

        <h1 class="profile-name"><%= user.name %></h1>

        <div class="profile-info">
            <div class="info-row">
                <span>Age</span>
                <strong><%= user.age %></strong>
            </div>

            <div class="info-row">
                <span>Height</span>
                <strong><%= user.height %></strong>
            </div>

            <div class="info-row">
                <span>Position</span>
                <strong><%= user.position %></strong>
            </div>
        </div>

        <div class="profile-comment">
            <p><%= user.comments %></p>
        </div>

       
        <a href="/stats/<%= user._id %>">
            <button class="stats-btn">Add Stats</button>
        </a>
        <a href="/add/<%= user._id %>">
            <button class="stats-btn">Check Stats</button>
        </a>

    </div>
</div>

</body>
</html>
