<!DOCTYPE html>
<html>
<head>
  <title</title>
  <link rel="stylesheet" href="/stylesheets/input.css">
</head>

<body style="color: white;">
<div class="sidebar">
  <h3>Cric Track</h3>

  <a href="/c">Home</a>
  <a href="/b">New Player</a>

  <% if (typeof user !== "undefined") { %>
    <a href="/d/<%= user._id %>">Profile</a>
    <a href="/stats/<%= user._id %>">Stats</a>
  <% } %>

</div>
<header>
  <div class="logo">
    
  </div>
  <div class="buttons">
    <a class="ct" href="/stats/<%= player._id %>">
      
    </a>
    <a class="cta" href="/d/<%= player._id %>">
    
    </a>
  </div>
</header>

<h1 class="add-stats-player-title"><%= player.name %>'s Stats</h1>

<div class="players">

  <% if (stats.length === 0) { %>
    <p style="text-align:center;">No stats yet.</p>
  <% } else { %>

    <% stats.forEach(function(match) { %>

      <button class="player-card" onclick="openModal(
        '<%= (match.matchName || match.date || 'Match').replace(/'/g, "\\'") %>',
        '<%= (match.date || '').replace(/'/g, "\\'") %>',
        '<%= match.runs %>',
        '<%= match.wickets %>',
        '<%= match.overs %>',
        '<%= (match.notes || "").replace(/'/g, "\\'") %>'
      )">

        <!-- Match name big -->
        <div class="add-stats-card-match-name"><%= match.matchName || match.date || 'Match' %></div>
        <!-- Date underneath -->
        <div class="add-stats-card-date"><%= match.date %></div>
        <a class="delete-button" style="color: rgb(226, 217, 29)"  href="/stats/delete/<%= match._id %>">
            Delete
      </a>

      <a class="edit-button" style="color: rgb(207, 29, 29);" href="/stats/change/<%= match._id %>">Edit</a>

      </button>

    <% }); %>

  <% } %>

</div>


<!-- Modal (view stats popup) -->
<div id="statsModal" class="stats-view-modal">

  <div class="stats-view-modal-content">

    <button type="button" class="stats-view-modal-close" onclick="closeModal()" aria-label="Close">×</button>

    <h2 class="stats-view-modal-match-name" id="mMatchName"></h2>
    <div class="stats-view-modal-date" id="mDate"></div>

    <h3 class="stats-view-modal-title">Match Stats</h3>

    <div class="stats-view-modal-row"><span class="stats-view-modal-label">Runs</span><span id="mRuns" class="stats-view-modal-value"></span></div>
    <div class="stats-view-modal-row"><span class="stats-view-modal-label">Wickets</span><span id="mWickets" class="stats-view-modal-value"></span></div>
    <div class="stats-view-modal-row"><span class="stats-view-modal-label">Overs</span><span id="mOvers" class="stats-view-modal-value"></span></div>
    <div class="stats-view-modal-row stats-view-modal-notes"><span class="stats-view-modal-label">Notes</span><span id="mNotes" class="stats-view-modal-value"></span></div>

  </div>

</div>


<script>
function openModal(matchName, date, runs, wickets, overs, notes) {
  document.getElementById("mMatchName").textContent = matchName || "Match";
  document.getElementById("mDate").textContent = date || "";
  document.getElementById("mRuns").textContent = runs;
  document.getElementById("mWickets").textContent = wickets;
  document.getElementById("mOvers").textContent = overs;
  document.getElementById("mNotes").textContent = notes || "";

  document.getElementById("statsModal").style.display = "flex";
}

function closeModal() {
  document.getElementById("statsModal").style.display = "none";
}
</script>

</body>
</html>
