<html>
    <head>
        <title> Cric Track</title>
        <link rel="stylesheet" href="/stylesheets/input.css">
    </head>
    <header>
        <div class="logo">
         <h2>
          Cric Track
         </h2>
        </div>
        
       
    </header>
    <body>
<div class="sidebar">
  <h3>Cric Track</h3>

  <a href="/c">Home</a>
  <a href="/b">New Player</a>

  <% if (typeof user !== "undefined") { %>
    <a href="/d/<%= user._id %>">Profile</a>
    <a href="/stats/<%= user._id %>">Stats</a>
  <% } %>

</div>
        <div class="players">
  <% users.forEach(user => { %>
    <a class="" text="white" href="/d/<%= user._id %>"><button class="player-card">
      <div class="player-name"  style="color: rgb(255, 255, 255);"><%= user.name %></div>
      <div class="player-position" style="color: rgb(255, 255, 255);"><%= user.position %></div>
      <a class="delete-button" style="color: rgb(99, 174, 82);" href="/delete/<%= user._id %>">Delete</a>
      <a class="edit-button" style="color: rgb(207, 29, 29);" href="/edit/<%= user._id %>">Edit</a>
      
    </button> </a>
  <% }) %>
</div>

        <a class="input" href="/b"><button>New player</button></a>
        

    </body>
</html>